/**
\brief	
*/
HRESULT ConvertRGB24toYUY2MMXFunct(
	std::uint8_t* dest,
	const std::uint8_t* source,
	int stride_dest,
	int stride_source,
	int width_element,
	int height_element )
{
	HRESULT hr = S_OK;

	SCA_CHECKNULLARG( dest );
	SCA_CHECKNULLARG( source );
	SCA_CHECKCONDITION( height_element <= 0 );
	SCA_CHECKCONDITION( width_element <= 0 );
	SCA_CHECKCONDITION( stride_dest <= 0 );
	SCA_CHECKCONDITION( stride_source <= 0 );
	SCA_CHECKCONDITION( stride_source <= stride_dest );
	SCA_CHECKCONDITION( width_element * 3 > stride_source );
	/**/

	int number_cycle_string = (width_element + ( (width_element & 0x7) ? 7 : 0) ) >> 3;
	int leak_source = stride_source - number_cycle_string * 24;
	int leak_dest = stride_dest - number_cycle_string * 16;

	SCA_CHECKCONDITION( leak_source < 0 );
	SCA_CHECKCONDITION( leak_dest < 0 );

	//process color for two pixel
	//y1 = 16.0 + ( 65.738 * r1 + 129.057 * g1 + 25.064 * b1 ) / 256.0;
	//u  =128.0 + (112.439 * r1 -  94.154 * g1 - 18.285 * b1 ) / 256.0;
	//y2 = 16.0 + ( 65.738 * r2 + 129.057 * g2 + 25.064 * b2 ) / 256.0;
	//v  =128.0 + (-37.945 * r1 -  74.494 * g1 +112.439 * b1 ) / 256.0;
	//y1 = 16.0 + ( 33.000 * r1 +  65.057 * g1 + 13.064 * b1 ) / 128.0;
	//u  =128.0 + ( 56.219 * r1 -  47.154 * g1 -  9.285 * b1 ) / 128.0;
	//v  =128.0 + (-19.045 * r1 -  37.294 * g1 + 56.239 * b1 ) / 128.0;

	short array_const_y[ 4 ] = 
	{
		33, 65, 13, 0
	};

	short array_const_u[ 4 ] = 
	{
		56, -47, -9, 0
	};

	short array_const_v[ 4 ] = 
	{
		-19, -37, 56, 0
	};
	/**/

	uint32_t array_const1[ 2 ] = 
	{
		16, 16
	};

	__asm
	{
		;eax-cycle string;
		;ebx-leak desination;
		;edx-leak source;
		;ecx-cycle col;
		;edi-destination;
		;esi-source;
		;mm0-first 8 bytes source - 4 word;
		;mm1-second 8 bytes source - 4 word and summ;
		;mm2-temp;
		;mm3-temp;
		;mm4-mull const y;
		;mm5-mull const u;
		;mm6-mull const v;
		;mm7-const dword 16;

		pushad;

		lea eax, array_const_y;
		movq mm4, [ eax ];
		lea eax, array_const_u;
		movq mm5, [ eax ];
		lea eax, array_const_v;
		movq mm6, [ eax ];
		lea eax, array_const1;
		movq mm7, [ eax ];

		mov ecx, height_element;
		mov ebx, leak_dest;
		mov edx, leak_source;
		mov edi, dest;
		mov esi, source;

		;mm0=[r1,g1,b1,0]words;
		;mm1=[r2,g2,b2,0]words;
		;mm2, mm3 - temp register;
		;eax-temp register;
		;edi-destination, after add 4 bytes;
#define RGB24TOYUY2_COMPLITE2PIXEL_MMX( mully_const, mullu_const, mullv_const, add_const ) \
	__asm movq mm2, mm0\
	__asm pmaddwd mm2, mully_const\
	__asm movq mm3, mm2\
	__asm psrlq mm3, 32\
	__asm paddd mm2, mm3\
	__asm psrad mm2, 7\
	__asm paddd mm2, add_const\
	__asm packssdw mm2, mm2\
	__asm packuswb mm2, mm2\
	__asm movd eax, mm2\
	__asm mov byte ptr [ edi + 0 ], al\
	__asm movq mm2, mm1\
	__asm pmaddwd mm2, mully_const\
	__asm movq mm3, mm2\
	__asm psrlq mm3, 32\
	__asm paddd mm2, mm3\
	__asm psrad mm2, 7\
	__asm paddd mm2, add_const\
	__asm packssdw mm2, mm2\
	__asm packuswb mm2, mm2\
	__asm movd eax, mm2\
	__asm mov byte ptr [ edi + 2 ], al\
	__asm paddsw mm0, mm1\
	__asm psraw mm0, 1\
	__asm movq mm1, mm0\
	__asm pslld add_const, 3\
	__asm pmaddwd mm0, mullu_const\
	__asm movq mm3, mm0\
	__asm psrlq mm3, 32\
	__asm paddd mm0, mm3\
	__asm psrad mm0, 7\
	__asm paddd mm0, add_const\
	__asm packssdw mm0, mm0\
	__asm packuswb mm0, mm0\
	__asm movd eax, mm0\
	__asm mov byte ptr [ edi + 1 ], al\
	__asm pmaddwd mm1, mullv_const\
	__asm movq mm3, mm1\
	__asm psrlq mm3, 32\
	__asm paddd mm1, mm3\
	__asm psrad mm1, 7\
	__asm paddd mm1, add_const\
	__asm packssdw mm1, mm1\
	__asm packuswb mm1, mm1\
	__asm movd eax, mm1\
	__asm mov byte ptr [ edi + 3 ], al\
	__asm psrld add_const, 3\
	__asm add edi, 4

cycle1:
		mov eax, number_cycle_string;

cycle2:
		push eax;

		pxor mm2, mm2;
		movq mm0, [ esi + 0 ];
		movq mm1, mm0;
		psrlq mm1, 24;
		punpcklbw mm0, mm2;
		punpcklbw mm1, mm2;
		psllq mm0, 16;
		psrlq mm0, 16;
		psllq mm1, 16;
		psrlq mm1, 16;
		RGB24TOYUY2_COMPLITE2PIXEL_MMX( mm4, mm5, mm6, mm7 );
		pxor mm2, mm2;
		movq mm0, [ esi + 6 ];
		movq mm1, mm0;
		psrlq mm1, 24;
		punpcklbw mm0, mm2;
		punpcklbw mm1, mm2;
		psllq mm0, 16;
		psrlq mm0, 16;
		psllq mm1, 16;
		psrlq mm1, 16;
		RGB24TOYUY2_COMPLITE2PIXEL_MMX( mm4, mm5, mm6, mm7 );
		pxor mm2, mm2;
		movq mm0, [ esi + 12 ];
		movq mm1, mm0;
		psrlq mm1, 24;
		punpcklbw mm0, mm2;
		punpcklbw mm1, mm2;
		psllq mm0, 16;
		psrlq mm0, 16;
		psllq mm1, 16;
		psrlq mm1, 16;
		RGB24TOYUY2_COMPLITE2PIXEL_MMX( mm4, mm5, mm6, mm7 );
		pxor mm2, mm2;
		movq mm0, [ esi + 16 ];
		psrlq mm0, 16;
		movq mm1, mm0;
		psrlq mm1, 24;
		punpcklbw mm0, mm2;
		punpcklbw mm1, mm2;
		psllq mm0, 16;
		psrlq mm0, 16;
		psllq mm1, 16;
		psrlq mm1, 16;
		RGB24TOYUY2_COMPLITE2PIXEL_MMX( mm4, mm5, mm6, mm7 );

		add esi, 24;
		pop eax;
		sub eax, 1;
		jg cycle2;

		add edi, ebx;
		add esi, edx;
		sub ecx, 1;
		jg cycle1;

#undef RGB24TOYUY2_COMPLITE2PIXEL_MMX

		popad;
		emms;
	}
	return hr;
}
/**
\brief	
*/
HRESULT ConvertRGB24toYUY2SSEFunct(
	std::uint8_t* dest,
	const std::uint8_t* source,
	int stride_dest,
	int stride_source,
	int width_element,
	int height_element )
{
	return ConvertRGB24toYUY2MMXFunct(
		dest,
		source,
		stride_dest,
		stride_source,
		width_element,
		height_element );
}
/**
\brief	
*/
HRESULT ConvertRGB24toYUY2SSE2Funct(
	std::uint8_t* dest,
	const std::uint8_t* source,
	int stride_dest,
	int stride_source,
	int width_element,
	int height_element )
{
	HRESULT hr = S_OK;

	SCA_CHECKNULLARG( dest );
	SCA_CHECKNULLARG( source );
	SCA_CHECKCONDITION( height_element <= 0 );
	SCA_CHECKCONDITION( width_element <= 0 );
	SCA_CHECKCONDITION( stride_dest <= 0 );
	SCA_CHECKCONDITION( stride_source <= 0 );
	SCA_CHECKCONDITION( stride_source <= stride_dest );
	SCA_CHECKCONDITION( width_element * 3 > stride_source );
	/**/

	int number_cycle_string = (width_element + ( (width_element & 0xF) ? 15 : 0) ) >> 4;
	int leak_source = stride_source - number_cycle_string * 48;
	int leak_dest = stride_dest - number_cycle_string * 32;

	SCA_CHECKCONDITION( leak_source < 0 );
	SCA_CHECKCONDITION( leak_dest < 0 );

	//process color for two pixel
	//y1 = 16.0 + ( 33.000 * r1 +  65.057 * g1 + 13.064 * b1 ) / 128.0;
	//u  =128.0 + ( 56.219 * r1 -  47.154 * g1 -  9.285 * b1 ) / 128.0;
	//v  =128.0 + (-19.045 * r1 -  37.294 * g1 + 56.239 * b1 ) / 128.0;

	short array_const_y[ 8 ] = 
	{
		33, 65, 13, 0, 33, 65, 13, 0
	};

	short array_const_u[ 8 ] = 
	{
		56, -47, -9, 0, 56, -47, -9, 0
	};

	short array_const_v[ 8 ] = 
	{
		-19, -37, 56, 0, -19, -37, 56, 0
	};
	/**/

	uint32_t array_const1[ 4 ] = 
	{
		16, 16, 16, 16
	};

	__asm
	{
		;eax-cycle string;
		;ebx-leak desination;
		;edx-leak source;;
		;ecx-cycle col;
		;edi-destination;
		;esi-source;
		;xmm0-first  16 bytes source - 8 word;
		;xmm1-second 16 bytes source - 8 word and summ;
		;xmm2-temp;
		;xmm3-temp;
		;xmm4-mull const y;
		;xmm5-mull const u;
		;xmm6-mull const v;
		;xmm7-const dword 16;

		pushad;

		lea eax, array_const_y;
		movdqu xmm4, [ eax ];
		lea eax, array_const_u;
		movdqu xmm5, [ eax ];
		lea eax, array_const_v;
		movdqu xmm6, [ eax ];
		lea eax, array_const1;
		movdqu xmm7, [ eax ];

		mov ecx, height_element;
		mov ebx, leak_dest;
		mov edx, leak_source;
		mov edi, dest;
		mov esi, source;

		;xmm0=[r1,g1,b1,0,r2,g2,b2,0]words;
		;xmm1=[r3,g3,b3,0,r4,g4,b4,0]words;
		;xmm2, mm3 - temp register;
		;eax-temp register;
		;edi-destination, after add 4 bytes;
#define RGB24TOYUY2_COMPLITE2PIXEL_SSE2( mully_const, mullu_const, mullv_const, add_const ) \
	__asm movdqa xmm2, xmm0\
	__asm pmaddwd xmm2, mully_const\
	__asm movdqa xmm3, xmm2\
	__asm psrldq xmm3, 4\
	__asm paddd xmm2, xmm3\
	__asm psrad xmm2, 7\
	__asm paddd xmm2, add_const\
	__asm packssdw xmm2, xmm2\
	__asm packuswb xmm2, xmm2\
	__asm movd eax, xmm2\
	__asm mov byte ptr [ edi + 0 ], al\
	__asm shr eax, 16\
	__asm mov byte ptr [ edi + 2 ], al\
	__asm movdqa xmm2, xmm1\
	__asm pmaddwd xmm2, mully_const\
	__asm movdqa xmm3, xmm2\
	__asm psrldq xmm3, 4\
	__asm paddd xmm2, xmm3\
	__asm psrad xmm2, 7\
	__asm paddd xmm2, add_const\
	__asm packssdw xmm2, xmm2\
	__asm packuswb xmm2, xmm2\
	__asm movd eax, xmm2\
	__asm mov byte ptr [ edi + 4 ], al\
	__asm shr eax, 16\
	__asm mov byte ptr [ edi + 6 ], al\
	__asm paddsw xmm0, xmm1\
	__asm psraw xmm0, 1\
	__asm movdqa xmm1, xmm0\
	__asm pslld add_const, 3\
	__asm pmaddwd xmm0, mullu_const\
	__asm movdqa xmm3, xmm0\
	__asm psrldq xmm3, 4\
	__asm paddd xmm0, xmm3\
	__asm psrad xmm0, 7\
	__asm paddd xmm0, add_const\
	__asm packssdw xmm0, xmm0\
	__asm packuswb xmm0, xmm0\
	__asm movd eax, xmm0\
	__asm mov byte ptr [ edi + 1 ], al\
	__asm shr eax, 16\
	__asm mov byte ptr [ edi + 5 ], al\
	__asm pmaddwd xmm1, mullv_const\
	__asm movdqa xmm3, xmm1\
	__asm psrldq xmm3, 4\
	__asm paddd xmm1, xmm3\
	__asm psrad xmm1, 7\
	__asm paddd xmm1, add_const\
	__asm packssdw xmm1, xmm1\
	__asm packuswb xmm1, xmm1\
	__asm movd eax, xmm1\
	__asm mov byte ptr [ edi + 3 ], al\
	__asm shr eax, 16\
	__asm mov byte ptr [ edi + 7 ], al\
	__asm psrld add_const, 3\
	__asm add edi, 8

cycle1:
		mov eax, number_cycle_string;

cycle2:
		push eax;

		movdqa xmm0, [ esi + 0 ];
		movdqa xmm1, xmm0;
		movdqa xmm2, xmm0;
		pslldq xmm0, 13;
		psrldq xmm0, 13;
		psrldq xmm2, 3;
		pslldq xmm2, 4;
		por xmm0, xmm2;
		movdqa xmm2, xmm1;
		pslldq xmm1, 7;
		psrldq xmm1, 13;
		psrldq xmm2, 9;
		pslldq xmm2, 4;
		por xmm1, xmm2;
		pxor xmm2, xmm2;
		punpcklbw xmm0, xmm2;
		punpcklbw xmm1, xmm2;
		RGB24TOYUY2_COMPLITE2PIXEL_SSE2( xmm4, xmm5, xmm6, xmm7 );

		movdqu xmm0, [ esi + 12 ];
		movdqa xmm1, xmm0;
		movdqa xmm2, xmm0;
		pslldq xmm0, 13;
		psrldq xmm0, 13;
		psrldq xmm2, 3;
		pslldq xmm2, 4;
		por xmm0, xmm2;
		movdqa xmm2, xmm1;
		pslldq xmm1, 7;
		psrldq xmm1, 13;
		psrldq xmm2, 9;
		pslldq xmm2, 4;
		por xmm1, xmm2;
		pxor xmm2, xmm2;
		punpcklbw xmm0, xmm2;
		punpcklbw xmm1, xmm2;
		RGB24TOYUY2_COMPLITE2PIXEL_SSE2( xmm4, xmm5, xmm6, xmm7 );

		movdqu xmm0, [ esi + 24 ];
		movdqa xmm1, xmm0;
		movdqa xmm2, xmm0;
		pslldq xmm0, 13;
		psrldq xmm0, 13;
		psrldq xmm2, 3;
		pslldq xmm2, 4;
		por xmm0, xmm2;
		movdqa xmm2, xmm1;
		pslldq xmm1, 7;
		psrldq xmm1, 13;
		psrldq xmm2, 9;
		pslldq xmm2, 4;
		por xmm1, xmm2;
		pxor xmm2, xmm2;
		punpcklbw xmm0, xmm2;
		punpcklbw xmm1, xmm2;
		RGB24TOYUY2_COMPLITE2PIXEL_SSE2( xmm4, xmm5, xmm6, xmm7 );

		movdqa xmm0, [ esi + 32 ];
		psrldq xmm0, 4;
		movdqa xmm1, xmm0;
		movdqa xmm2, xmm0;
		pslldq xmm0, 13;
		psrldq xmm0, 13;
		psrldq xmm2, 3;
		pslldq xmm2, 4;
		por xmm0, xmm2;
		movdqa xmm2, xmm1;
		pslldq xmm1, 7;
		psrldq xmm1, 13;
		psrldq xmm2, 9;
		pslldq xmm2, 4;
		por xmm1, xmm2;
		pxor xmm2, xmm2;
		punpcklbw xmm0, xmm2;
		punpcklbw xmm1, xmm2;
		pxor xmm2, xmm2;
		RGB24TOYUY2_COMPLITE2PIXEL_SSE2( xmm4, xmm5, xmm6, xmm7 );

		add esi, 48;
		pop eax;
		sub eax, 1;
		jg cycle2;

		add edi, ebx;
		add esi, edx;
		sub ecx, 1;
		jg cycle1;

#undef RGB24TOYUY2_COMPLITE2PIXEL_SSE2

		popad;
	}
	return hr;
}
#endif

/**
\brief	
*/
HRESULT ConvertRGB24toY8SSE2Funct(
	std::uint8_t* dest,
	const std::uint8_t* source,
	int stride_dest,
	int stride_source,
	int width_element,
	int height_element )
{
	HRESULT hr = S_OK;

	SCA_CHECKNULLARG( dest );
	SCA_CHECKNULLARG( source );

  set(U3_INSTALL_DIR_EXTERNAL_LIB_V4L2CPP ${install_dir}/src/v4l2cpp-util-build/${U3_EXTERNAL_LIB_V4L2CPP_FILE_NAME})
endif()

u3_make_fake_file(FILE_NAME ${U3_INSTALL_DIR_EXTERNAL_LIB_V4L2CPP} CONTENT "v4l2cpp")


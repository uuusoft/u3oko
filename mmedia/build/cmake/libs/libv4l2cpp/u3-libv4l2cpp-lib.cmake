u3_project_add(
  PROJECT_NAME
  ${U3_NAME_EXTERNAL_LIB_V4L2CPP_UTIL}
  #PROJECT_VERSION       "v${U3_VERSION_EXTERNAL_LIB_V4L2CPP}"
  URL_TO_BIN
  ${U3_URL_TO_EXTERNAL_LIB_V4L2CPP_BIN}
  NAME_BIN_MD5
  U3_EXTERNAL_LIB_V4L2CPP${U3_VERSION_EXTERNAL_LIB_V4L2CPP_CID}_MD5_${U3_ENV_GEN_POSTFIX_VARIABLE_NAME_TO_EXT_LIB}

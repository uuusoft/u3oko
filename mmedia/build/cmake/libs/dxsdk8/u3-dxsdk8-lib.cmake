if(NOT ${U3_SYSTEM_NAME} STREQUAL ${U3_SYSTEM_NAME_WINDOWS})
  message(FATAL_ERROR "U3_SYSTEM_NAME=${U3_SYSTEM_NAME} not supported")
endif()

if(NOT ${U3_ENV_PTR_BITS_COUNT} EQUAL 32)
  #message( FATAL_ERROR "U3_ENV_PTR_BITS_COUNT=${U3_ENV_PTR_BITS_COUNT} not supported" )
endif()

include(ExternalProject)
include("./build/cmake/libs/dxsdk8/u3-dxsdk8-lib-values.cmake")

set(U3_NAME_EXTERNAL_LIB_DXSDK8_UTIL ${U3_NAME_EXTERNAL_LIB_DXSDK8}-util)

message(
  NOTICE
  "${U3_MARK_WARNING} change U3_URL_TO_EXTERNAL_LIB_DXSDK8_SRC_EXT from ${U3_URL_TO_EXTERNAL_LIB_DXSDK8_SRC_EXT} to ${U3_URL_TO_EXTERNAL_LIB_DXSDK8_SRC} wtf external link not working"
)
set(U3_URL_TO_EXTERNAL_LIB_DXSDK8_SRC_EXT ${U3_URL_TO_EXTERNAL_LIB_DXSDK8_SRC})

u3_project_add(
  PROJECT_NAME
  ${U3_NAME_EXTERNAL_LIB_DXSDK8_UTIL}
  PROJECT_VERSION
  ${U3_VERSION_EXTERNAL_LIB_DXSDK8}
  URL_TO_BIN
  ${U3_URL_TO_EXTERNAL_LIB_DXSDK8_BIN}
  NAME_BIN_MD5
  U3_EXTERNAL_LIB_DXSDK8${U3_VERSION_EXTERNAL_LIB_DXSDK8_CID}_MD5_${U3_ENV_GEN_POSTFIX_VARIABLE_NAME_TO_EXT_LIB}
  URL_TO_SRC
  ${U3_URL_TO_EXTERNAL_LIB_DXSDK8_SRC}
  SRC_MD5
  ${U3_EXTERNAL_LIB_DXSDK8_MD5}
  URL_TO_SRC_EXT
  ${U3_URL_TO_EXTERNAL_LIB_DXSDK8_SRC_EXT}
  SRC_EXT_MD5
  ${U3_EXTERNAL_LIB_DXSDK8_MD5}
  USE_HTTP_FOR_EXT_SRC
  TRUE
  BUILD_IN_SOURCE
  FALSE
  IT_CMAKE_PROJECT
  FALSE
  FORCE_COMPILE
  FALSE)

ExternalProject_Get_Property(${U3_NAME_EXTERNAL_LIB_DXSDK8_UTIL} install_dir)

if(${U3_GVXX_PROJECT_ADD_SOURCE_TYPE} STREQUAL "U3_ADD_PROJECT_RESULT_BIN")
  set(U3_LIB_DIR_EXTERNAL_LIB_DXSDK8 ${install_dir}/src/dxsdk8-util/lib)
  set(U3_INSTALL_DIR_EXTERNAL_LIB_DXSDK8 "${install_dir}/src/dxsdk8-util/lib/d3d8.lib")
else()
  set(U3_LIB_DIR_EXTERNAL_LIB_DXSDK8 ${install_dir}/src/dxsdk8-util/lib)
  set(U3_INSTALL_DIR_EXTERNAL_LIB_DXSDK8 "${install_dir}/src/dxsdk8-util/lib/d3d8.lib")
endif()

set(U3_DEPENDENCY_TARGETS_LIST ${U3_DEPENDENCY_TARGETS_LIST} ${U3_NAME_EXTERNAL_LIB_DXSDK8_UTIL})

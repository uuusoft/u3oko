cmake_host_system_information(RESULT U3_OS_NAME QUERY OS_NAME)
cmake_host_system_information(RESULT U3_OS_RELEASE QUERY OS_RELEASE)
cmake_host_system_information(RESULT U3_OS_VERSION QUERY OS_VERSION)
cmake_host_system_information(RESULT U3_OS_OS_PLATFORM QUERY OS_PLATFORM)
#message(FATAL_ERROR "U3_OS_NAME=${U3_OS_NAME}")
#message(FATAL_ERROR "U3_OS_RELEASE=${U3_OS_RELEASE}")
#message(FATAL_ERROR "U3_OS_VERSION=${U3_OS_VERSION}")
#message(FATAL_ERROR "U3_OS_VERSION=${U3_OS_OS_PLATFORM}")

u3_get_major_version(CMAKE_CXX_COMPILER_VERSION U3_CMAKE_CXX_COMPILER_VERSION_CID)
u3_get_major_version(CMAKE_C_COMPILER_VERSION U3_CMAKE_C_COMPILER_VERSION_CID)

if(NOT U3_CMAKE_CXX_COMPILER_VERSION_CID OR NOT U3_CMAKE_C_COMPILER_VERSION_CID)
  message(FATAL_ERROR "U3_CMAKE_CXX_COMPILER_VERSION_CID=${U3_CMAKE_CXX_COMPILER_VERSION_CID} U3_CMAKE_C_COMPILER_VERSION_CID=${U3_CMAKE_C_COMPILER_VERSION_CID} not found")
endif()

set(U3_ENV_GEN_COMPILERS_ID "${CMAKE_CXX_COMPILER_ID}-${U3_CMAKE_CXX_COMPILER_VERSION_CID}-${CMAKE_C_COMPILER_ID}-${U3_CMAKE_C_COMPILER_VERSION_CID}-${CMAKE_ASM_COMPILER_ID}")
set(U3_ENV_GEN_POSTFIX_NAME_TO_EXT_LIB "${U3_SYSTEM_NAME}-${U3_ENV_GEN_COMPILERS_ID}-${CMAKE_SYSTEM_PROCESSOR}-${CMAKE_BUILD_TYPE}-${U3_SANITY_BUILD_TYPE}")
set(U3_ENV_GEN_FOLDER_EXTLIBS "./../../u3externals-${U3_ENV_GEN_POSTFIX_NAME_TO_EXT_LIB}")
set(U3_ENV_GEN_FOLDER_EXTLIBS "./../../u3temp-${U3_ENV_GEN_POSTFIX_NAME_TO_EXT_LIB}")

string(REPLACE "-" "_" U3_ENV_GEN_POSTFIX_VARIABLE_NAME_TO_EXT_LIB ${U3_ENV_GEN_POSTFIX_NAME_TO_EXT_LIB})

string(TOLOWER ${CMAKE_BUILD_TYPE} U3_ENV_CMAKE_BUILD_TYPE_LC)
string(TOUPPER ${CMAKE_BUILD_TYPE} U3_ENV_CMAKE_BUILD_TYPE_UC)
string(TIMESTAMP U3_TIME_START_BUILD "%Y-%m-%d:%H.%m.%S.%f")

math(EXPR U3_ENV_PTR_BITS_COUNT "${CMAKE_SIZEOF_VOID_P} * 8")

message(NOTICE "****** BEGIN DUMP GENERATE VARIABLES")
message(NOTICE "*** U3_ENV_GEN_FOLDER_EXTLIBS=${U3_ENV_GEN_FOLDER_EXTLIBS}")
message(NOTICE "*** U3_ENV_GEN_POSTFIX_NAME_TO_EXT_LIB=${U3_ENV_GEN_POSTFIX_NAME_TO_EXT_LIB}")
message(NOTICE "*** U3_ENV_GEN_POSTFIX_VARIABLE_NAME_TO_EXT_LIB=${U3_ENV_GEN_POSTFIX_VARIABLE_NAME_TO_EXT_LIB}")
message(NOTICE "*** U3_ENV_CMAKE_BUILD_TYPE_LC=${U3_ENV_CMAKE_BUILD_TYPE_LC}")
message(NOTICE "*** U3_ENV_CMAKE_BUILD_TYPE_UC=${U3_ENV_CMAKE_BUILD_TYPE_UC}")
message(NOTICE "*** U3_ENV_PTR_BITS_COUNT=${U3_ENV_PTR_BITS_COUNT}")
message(NOTICE "****** END DUMP GENERATE VARIABLES")

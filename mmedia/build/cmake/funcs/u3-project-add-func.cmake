include("./build/cmake/funcs/u3-url-validate-func.cmake")

macro(u3_project_add_cmake)
  set(U3_FUNCT_RESULT FALSE)

  if(NOT U3_FORCE_USE_EXT_SOURCE_FOR_EXTLIBS)
    u3_validate_url(URL ${U3_GVXX_PROJECT_ADD_URL_TO_SRC})
    #message(AUTHOR_WARNING "u3_project_add_cmake::---->U3_GVXX_PROJECT_ADD_URL_TO_SRC=${U3_GVXX_PROJECT_ADD_URL_TO_SRC} U3_FUNCT_RESULT=${U3_FUNCT_RESULT}")

    if(U3_FUNCT_RESULT)
      if(NOT U3_GVXX_PROJECT_ADD_USE_HTTP_FOR_EXTERNAL_SRC AND NOT ${U3_GVXX_PROJECT_ADD_PROJECT_VERSION} STREQUAL "")
        message(NOTICE "U3_GVXX_PROJECT_ADD_SOURCE_PATCH_COMMAND=${U3_GVXX_PROJECT_ADD_SOURCE_PATCH_COMMAND}")
        #if(0)
        #if( NOT U3_GVXX_PROJECT_ADD_SOURCE_PATCH_COMMAND OR ${U3_GVXX_PROJECT_ADD_SOURCE_PATCH_COMMAND} STREQUAL "" )
        if("${U3_GVXX_PROJECT_ADD_SOURCE_PATCH_COMMAND}" STREQUAL "")
          set(U3_GVXX_PROJECT_ADD_SOURCE_PATCH_COMMAND_WITH_GIT_SWITCH "${GIT_EXECUTABLE};switch;--detach;${U3_GVXX_PROJECT_ADD_PROJECT_VERSION}")
        else()
          set(U3_GVXX_PROJECT_ADD_SOURCE_PATCH_COMMAND_WITH_GIT_SWITCH
              "${GIT_EXECUTABLE};switch;--detach;${U3_GVXX_PROJECT_ADD_PROJECT_VERSION};&&" ${U3_GVXX_PROJECT_ADD_SOURCE_PATCH_COMMAND})
        endif()
        #set( U3_GVXX_PROJECT_ADD_SOURCE_PATCH_COMMAND_WITH_GIT_SWITCH ${U3_GVXX_PROJECT_ADD_SOURCE_PATCH_COMMAND} )
        #message( FATAL_ERROR "U3_GVXX_PROJECT_ADD_SOURCE_PATCH_COMMAND_WITH_GIT_SWITCH=${U3_GVXX_PROJECT_ADD_SOURCE_PATCH_COMMAND_WITH_GIT_SWITCH}" )
      else()
        set(U3_GVXX_PROJECT_ADD_SOURCE_PATCH_COMMAND_WITH_GIT_SWITCH ${U3_GVXX_PROJECT_ADD_SOURCE_PATCH_COMMAND})
      endif()

      #message( FATAL_ERROR "U3_GVXX_PROJECT_ADD_SOURCE_PATCH_COMMAND_WITH_GIT_SWITCH=${U3_GVXX_PROJECT_ADD_SOURCE_PATCH_COMMAND_WITH_GIT_SWITCH}" )
      ExternalProject_Add(
        ${U3_GVXX_PROJECT_ADD_PROJECT_NAME}
        URL ${U3_GVXX_PROJECT_ADD_URL_TO_SRC}
        PREFIX ${U3_ENV_GEN_FOLDER_EXTLIBS}/${U3_GVXX_PROJECT_ADD_PROJECT_NAME}
        DOWNLOAD_DIR ${U3_ENV_GEN_FOLDER_EXTLIBS_DOWNLOADS}
        DOWNLOAD_NO_PROGRESS TRUE
        URL_HASH MD5=${U3_GVXX_PROJECT_ADD_SRC_MD5}
        DOWNLOAD_EXTRACT_TIMESTAMP FALSE
        TIMEOUT 1200
        PATCH_COMMAND ${U3_GVXX_PROJECT_ADD_SOURCE_PATCH_COMMAND_WITH_GIT_SWITCH}
        #CONFIGURE_COMMAND           "git switch --detach " ${U3_GVXX_PROJECT_ADD_PROJECT_VERSION}
        BUILD_COMMAND ${CMAKE_COMMAND} --build . --config ${CMAKE_BUILD_TYPE}
        BUILD_IN_SOURCE ${U3_GVXX_PROJECT_ADD_BUILD_IN_SOURCE}
        BUILD_ALWAYS FALSE
        INSTALL_COMMAND ""
        CMAKE_ARGS -DCMAKE_BUILD_TYPE:STRING=${CMAKE_BUILD_TYPE}
                   -DCMAKE_SYSTEM_NAME:STRING=${CMAKE_SYSTEM_NAME}
                   -DENABLE_SHARED=FALSE
                   -DCMAKE_POSITION_INDEPENDENT_CODE=${CMAKE_POSITION_INDEPENDENT_CODE}
                   -DCMAKE_SYSTEM_PROCESSOR:STRING=${CMAKE_SYSTEM_PROCESSOR}
                   -DCMAKE_C_COMPILER=${CMAKE_C_COMPILER}
                   -DCMAKE_CXX_COMPILER=${CMAKE_CXX_COMPILER}
                   -DCMAKE_ASM_COMPILER=${CMAKE_ASM_COMPILER}
                   -DCMAKE_TOOLCHAIN_FILE:FILEPATH=${CMAKE_TOOLCHAIN_FILE}
                   -DCMAKE_POLICY_DEFAULT_CMP0057:STRING=NEW
                   -DCMAKE_POLICY_VERSION_MINIMUM=3.10
                   ${U3_SHARED_COMPILE_DEF_CPP}
                   #-DCMAKE_SHARED_LINKER_FLAGS:STRING="${CMAKE_SHARED_LINKER_FLAGS} --allow-multiple-definition -Wl,-allow-multiple-definition"
                   #-E env LDFLAGS="--allow-multiple-definition"
      )

      set(U3_GVXX_PROJECT_ADD_SOURCE_TYPE "U3_ADD_PROJECT_RESULT_SRC")
    endif()
  endif()

  if(NOT U3_FUNCT_RESULT AND NOT U3_FORCE_USE_LOCAL_SOURCE_FOR_EXTLIBS)
    if(U3_GVXX_PROJECT_ADD_USE_HTTP_FOR_EXTERNAL_SRC)
      ExternalProject_Add(
        ${U3_GVXX_PROJECT_ADD_PROJECT_NAME}
        URL ${U3_GVXX_PROJECT_ADD_URL_TO_SRC_EXT}
        PREFIX ${U3_ENV_GEN_FOLDER_EXTLIBS}/${U3_GVXX_PROJECT_ADD_PROJECT_NAME}
        DOWNLOAD_DIR ${U3_ENV_GEN_FOLDER_EXTLIBS_DOWNLOADS}
        DOWNLOAD_NO_PROGRESS TRUE
        URL_HASH MD5=${U3_GVXX_PROJECT_ADD_SRC_EXT_MD5}
        DOWNLOAD_EXTRACT_TIMESTAMP FALSE
        TIMEOUT 1200
        PATCH_COMMAND ${U3_GVXX_PROJECT_ADD_SOURCE_PATCH_COMMAND}
        #CONFIGURE_COMMAND           "git switch --detach " ${U3_GVXX_PROJECT_ADD_PROJECT_VERSION}
        BUILD_COMMAND ${CMAKE_COMMAND} --build . --config ${CMAKE_BUILD_TYPE}
        BUILD_IN_SOURCE ${U3_GVXX_PROJECT_ADD_BUILD_IN_SOURCE}
        BUILD_ALWAYS FALSE
        INSTALL_COMMAND ""
        CMAKE_ARGS -DCMAKE_BUILD_TYPE:STRING=${CMAKE_BUILD_TYPE}
                   -DCMAKE_SYSTEM_NAME:STRING=${CMAKE_SYSTEM_NAME}
                   -DENABLE_SHARED=FALSE
                   -DCMAKE_POSITION_INDEPENDENT_CODE=${CMAKE_POSITION_INDEPENDENT_CODE}
                   -DCMAKE_SYSTEM_PROCESSOR:STRING=${CMAKE_SYSTEM_PROCESSOR}
                   -DCMAKE_C_COMPILER=${CMAKE_C_COMPILER}
                   -DCMAKE_CXX_COMPILER=${CMAKE_CXX_COMPILER}
                   -DCMAKE_ASM_COMPILER=${CMAKE_ASM_COMPILER}
                   -DCMAKE_TOOLCHAIN_FILE:FILEPATH=${CMAKE_TOOLCHAIN_FILE}
                   -DCMAKE_POLICY_DEFAULT_CMP0057:STRING=NEW
                   -DCMAKE_POLICY_VERSION_MINIMUM=3.10
                   ${U3_SHARED_COMPILE_DEF_CPP}
                   #-DCMAKE_SHARED_LINKER_FLAGS:STRING="${CMAKE_SHARED_LINKER_FLAGS} --allow-multiple-definition -Wl,-allow-multiple-definition"
                   #-E env LDFLAGS="--allow-multiple-definition"
      )

      set(U3_GVXX_PROJECT_ADD_SOURCE_TYPE "U3_ADD_PROJECT_RESULT_SRC_EXT_URL")
    else()
      ExternalProject_Add(
        ${U3_GVXX_PROJECT_ADD_PROJECT_NAME}
        GIT_REPOSITORY ${U3_GVXX_PROJECT_ADD_URL_TO_SRC_EXT}
        GIT_TAG ${U3_GVXX_PROJECT_ADD_PROJECT_VERSION}
        GIT_PROGRESS FALSE
        PREFIX ${U3_ENV_GEN_FOLDER_EXTLIBS}/${U3_GVXX_PROJECT_ADD_PROJECT_NAME}
        DOWNLOAD_EXTRACT_TIMESTAMP FALSE
        TIMEOUT 1200
        PATCH_COMMAND ${U3_GVXX_PROJECT_ADD_SOURCE_PATCH_COMMAND}
        #CONFIGURE_COMMAND           ""
        BUILD_COMMAND ${CMAKE_COMMAND} --build . --config ${CMAKE_BUILD_TYPE}
        BUILD_IN_SOURCE ${U3_GVXX_PROJECT_ADD_BUILD_IN_SOURCE}
        BUILD_ALWAYS FALSE
        INSTALL_COMMAND ""
        CMAKE_ARGS -DCMAKE_BUILD_TYPE:STRING=${CMAKE_BUILD_TYPE}
                   -DCMAKE_SYSTEM_NAME:STRING=${CMAKE_SYSTEM_NAME}
                   -DENABLE_SHARED=FALSE
                   -DCMAKE_POSITION_INDEPENDENT_CODE=${CMAKE_POSITION_INDEPENDENT_CODE}
                   -DCMAKE_SYSTEM_PROCESSOR:STRING=${CMAKE_SYSTEM_PROCESSOR}
                   -DCMAKE_C_COMPILER=${CMAKE_C_COMPILER}
                   -DCMAKE_CXX_COMPILER=${CMAKE_CXX_COMPILER}
                   -DCMAKE_ASM_COMPILER=${CMAKE_ASM_COMPILER}
                   -DCMAKE_TOOLCHAIN_FILE:FILEPATH=${CMAKE_TOOLCHAIN_FILE}
                   -DCMAKE_POLICY_DEFAULT_CMP0057:STRING=NEW
                   -DCMAKE_POLICY_VERSION_MINIMUM=3.10
                   ${U3_SHARED_COMPILE_DEF_CPP}
                   #-DCMAKE_SHARED_LINKER_FLAGS:STRING="${CMAKE_SHARED_LINKER_FLAGS} --allow-multiple-definition -Wl,-allow-multiple-definition"
                   #-E env LDFLAGS="--allow-multiple-definition"
      )

      set(U3_GVXX_PROJECT_ADD_SOURCE_TYPE "U3_ADD_PROJECT_RESULT_SRC_EXT_GIT")
    endif()
  endif()
endmacro(u3_project_add_cmake)


function(u3_project_add)
  cmake_parse_arguments(
    U3_GVXX_PROJECT_ADD ""
    "USE_HTTP_FOR_EXTERNAL_SRC;PROJECT_NAME;PROJECT_VERSION;URL_TO_BIN;NAME_BIN_MD5;BIN_MD5;URL_TO_SRC;SRC_MD5;URL_TO_SRC_EXT;SRC_EXT_MD5;BUILD_IN_SOURCE;IT_CMAKE_PROJECT;FORCE_COMPILE"
    "SOURCE_PATCH_COMMAND" ${ARGN})

  if(NOT DEFINED U3_GVXX_PROJECT_ADD_PROJECT_NAME)
    message(FATAL_ERROR "U3_GVXX_PROJECT_ADD_PROJECT_NAME not defined")
  endif()

  message(STATUS "****** add external project")
  message(STATUS "*** U3_GVXX_PROJECT_ADD_PROJECT_NAME=${U3_GVXX_PROJECT_ADD_PROJECT_NAME}")
  message(STATUS "*** U3_GVXX_PROJECT_ADD_PROJECT_VERSION=${U3_GVXX_PROJECT_ADD_PROJECT_VERSION}")
  message(STATUS "*** U3_GVXX_PROJECT_ADD_NAME_BIN_MD5=${U3_GVXX_PROJECT_ADD_NAME_BIN_MD5}")
  message(STATUS "*** U3_GVXX_PROJECT_ADD_BIN_MD5=${U3_GVXX_PROJECT_ADD_BIN_MD5}")
  message(STATUS "*** U3_GVXX_PROJECT_ADD_URL_TO_SRC=${U3_GVXX_PROJECT_ADD_URL_TO_SRC}")
  message(STATUS "*** U3_GVXX_PROJECT_ADD_SRC_EXT_MD5=${U3_GVXX_PROJECT_ADD_SRC_EXT_MD5}")
  message(STATUS "*** U3_GVXX_PROJECT_ADD_URL_TO_BIN=${U3_GVXX_PROJECT_ADD_URL_TO_BIN}")
  message(STATUS "*** U3_GVXX_PROJECT_ADD_SOURCE_PATCH_COMMAND=${U3_GVXX_PROJECT_ADD_SOURCE_PATCH_COMMAND}")
  message(STATUS "*** U3_GVXX_PROJECT_ADD_FORCE_COMPILE=${U3_GVXX_PROJECT_ADD_FORCE_COMPILE}")
  message(STATUS "******")

  set(U3_FUNCT_RESULT FALSE)
  set(U3_GVXX_PROJECT_ADD_SOURCE_TYPE "")

  # load prebuild artifacts
  if(NOT U3_FORCE_COMPILE_ALL_EXTLIBS AND NOT U3_GVXX_PROJECT_ADD_FORCE_COMPILE)
    u3_validate_url(URL ${U3_GVXX_PROJECT_ADD_URL_TO_BIN})
    #message(AUTHOR_WARNING "u3_project_add::---->U3_GVXX_PROJECT_ADD_URL_TO_BIN=${U3_GVXX_PROJECT_ADD_URL_TO_BIN} U3_FUNCT_RESULT=${U3_FUNCT_RESULT}")
    if(U3_FUNCT_RESULT)
      ExternalProject_Add(
        ${U3_GVXX_PROJECT_ADD_PROJECT_NAME}
        URL ${U3_GVXX_PROJECT_ADD_URL_TO_BIN}
        PREFIX "${U3_ENV_GEN_FOLDER_EXTLIBS}/${U3_GVXX_PROJECT_ADD_PROJECT_NAME}"
        DOWNLOAD_DIR "${U3_ENV_GEN_FOLDER_EXTLIBS_DOWNLOADS}"
        DOWNLOAD_NO_PROGRESS FALSE
        URL_HASH MD5=${U3_GVXX_PROJECT_ADD_BIN_MD5}
        DOWNLOAD_EXTRACT_TIMESTAMP FALSE
        TIMEOUT 1200
        PATCH_COMMAND ""
        CONFIGURE_COMMAND ""
        BUILD_COMMAND ""
        INSTALL_COMMAND "")

      set(U3_GVXX_PROJECT_ADD_SOURCE_TYPE "U3_ADD_PROJECT_RESULT_BIN")
    endif()
  endif()

  if(NOT U3_FUNCT_RESULT)
    if(U3_GVXX_PROJECT_ADD_IT_CMAKE_PROJECT)
      u3_project_add_cmake()
    else()
      u3_project_add_not_cmake()
    endif()
    if(U3_DBG_STOP_BEFORE_COMPILE_EXTLIBS)
      message(AUTHOR_WARNING "U3_GVXX_PROJECT_ADD_NAME_BIN_MD5=${U3_GVXX_PROJECT_ADD_NAME_BIN_MD5}")
      message(AUTHOR_WARNING "U3_GVXX_PROJECT_ADD_BIN_MD5=${U3_GVXX_PROJECT_ADD_BIN_MD5}")
      message(AUTHOR_WARNING "U3_GVXX_PROJECT_ADD_URL_TO_BIN=${U3_GVXX_PROJECT_ADD_URL_TO_BIN}")
      message(FATAL_ERROR "${U3_MARK_DEV}U3_DBG_STOP_BEFORE_COMPILE_EXTLIBS=${U3_DBG_STOP_BEFORE_COMPILE_EXTLIBS}")
    endif()
  endif()

  set(U3_FUNCT_RESULT ${U3_FUNCT_RESULT} PARENT_SCOPE)
  set(U3_GVXX_PROJECT_ADD_SOURCE_TYPE ${U3_GVXX_PROJECT_ADD_SOURCE_TYPE} PARENT_SCOPE)
endfunction(u3_project_add)

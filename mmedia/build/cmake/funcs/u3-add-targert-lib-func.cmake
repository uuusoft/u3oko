function(u3_add_target_lib)
  cmake_parse_arguments(U3_GVXX_ADD_TARGET_LIB "" "TARGET_NAME;SOURCE_PATH" "" ${ARGN})

  message(VERBOSE "+++ Add library ${U3_GVXX_ADD_TARGET_LIB_TARGET_NAME}")
  message(VERBOSE "+++ U3_SHARED_COMPILE_DEF_CPP=${U3_SHARED_COMPILE_DEF_CPP}")
  message(VERBOSE "+++ U3_SHARED_COMPILE_OPTIONS_CPP=${U3_SHARED_COMPILE_OPTIONS_CPP}")
  message(VERBOSE "+++ U3_LIBS_3RD_STATIC_LIST=${U3_LIBS_3RD_STATIC_LIST}")
  message(VERBOSE "+++ U3_DEPENDENCY_TARGETS_LIST=${U3_DEPENDENCY_TARGETS_LIST}")

  file(TO_CMAKE_PATH "${U3_GVXX_ADD_TARGET_LIB_SOURCE_PATH}" ${U3_GVXX_ADD_TARGET_LIB_TARGET_NAME}-PATH)
  file(GLOB_RECURSE ${U3_GVXX_ADD_TARGET_LIB_TARGET_NAME}-FILES "${${U3_GVXX_ADD_TARGET_LIB_TARGET_NAME}-PATH}" "${${U3_GVXX_ADD_TARGET_LIB_TARGET_NAME}-PATH}/*.cpp")

  add_library(${U3_GVXX_ADD_TARGET_LIB_TARGET_NAME} STATIC ${${U3_GVXX_ADD_TARGET_LIB_TARGET_NAME}-FILES})

  target_compile_definitions(${U3_GVXX_ADD_TARGET_LIB_TARGET_NAME} PUBLIC ${U3_SHARED_COMPILE_DEF_CPP})
  target_compile_options(${U3_GVXX_ADD_TARGET_LIB_TARGET_NAME} PUBLIC ${U3_SHARED_COMPILE_OPTIONS_CPP} $<$<COMPILE_LANGUAGE:CXX>:${shared_cpp_compile_options}>)
  add_dependencies(${U3_GVXX_ADD_TARGET_LIB_TARGET_NAME} ${U3_LIBS_3RD_STATIC_LIST} ${U3_DEPENDENCY_TARGETS_LIST})

endfunction(u3_add_target_lib)

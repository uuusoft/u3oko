macro(u3_dump_var var)
  message(NOTICE "*** ${var}=${${var}}")
endmacro(u3_dump_var)

function(u3_dump_vars)
  #return()
  cmake_parse_arguments(U3_GVXX_DUMP_VARS "" "STATUS_INFO;DEBUG_STOP" "" ${ARGN})

  message(NOTICE "****** begin dump ${U3_GVXX_DUMP_VARS_STATUS_INFO}")

  u3_dump_var(CMAKE_VERSION)
  u3_dump_var(CMAKE_SYSTEM_VERSION)
  u3_dump_var(U3_SANITY_BUILD_TYPE)
  u3_dump_var(U3_URL_TO_EXTERNAL_LIBS_SRC)
  u3_dump_var(U3_URL_TO_EXTERNAL_LIBS_BIN)
  u3_dump_var(U3_FORCE_COMPILE_ALL_EXT_LIBS)
  u3_dump_var(U3_FORCE_USE_EXT_SOURCE_FOR_EXT_LIBS)
  u3_dump_var(U3_DBG_EXTERNAL_LIB_SKIP_SQLITE)
  u3_dump_var(U3_TARGET_PROPERTY_MSVC_RUNTIME_LIBRARY)
  u3_dump_var(U3_BUILD_MODULES_AS_LIBS)
  u3_dump_var(CMAKE_MESSAGE_LOG_LEVEL)
  u3_dump_var(U3_ENV_PTR_BITS_COUNT)
  u3_dump_var(U3_SYSTEM_NAME)
  u3_dump_var(CMAKE_SYSTEM_NAME)
  u3_dump_var(CMAKE_GENERATOR_PLATFORM)
  u3_dump_var(CMAKE_SYSTEM_PROCESSOR)
  u3_dump_var(CMAKE_MAKE_PROGRAM)
  u3_dump_var(CMAKE_BUILD_TYPE)
  u3_dump_var(CMAKE_C_COMPILER)
  u3_dump_var(CMAKE_CXX_COMPILER)
  u3_dump_var(CMAKE_ASM_COMPILER)
  u3_dump_var(CMAKE_TOOLCHAIN_FILE)
  u3_dump_var(U3_BUILD_PATH_TO_LIBS)
  u3_dump_var(U3_LIBS_OUR_VARIABLE_LIST)
  u3_dump_var(U3_LIBS_OUR_STATIC_LIST)
  u3_dump_var(U3_LIBS_3RD_STATIC_LIST)
  u3_dump_var(U3_LIBS_SYSTEM_STATIC_LIST)
  u3_dump_var(U3_DEPENDENCY_TARGETS_LIST)
  u3_dump_var(U3_SHARED_COMPILE_DEF_CPP)
  u3_dump_var(U3_SHARED_LINK_OPTIONS_CPP)
  u3_dump_var(CMAKE_C_FLAGS)
  u3_dump_var(CMAKE_CXX_FLAGS)
  u3_dump_var(CMAKE_CXX_FLAGS_DEBUG)
  u3_dump_var(CMAKE_CXX_FLAGS_RELEASE)
  u3_dump_var(CMAKE_EXE_LINKER_FLAGS)

  if(${U3_SYSTEM_NAME} STREQUAL ${U3_SYSTEM_NAME_ANDROID})
    u3_dump_var(ANDROID_NDK)
    u3_dump_var(ANDROID_ABI)
    u3_dump_var(ANDROID_PLATFORM)
    u3_dump_var(ANDROID_TOOLCHAIN)
    u3_dump_var(ANDROID_STL)
    u3_dump_var(ANDROID_CPP_FEATURES)
  endif()

  message(NOTICE "****** end dump ${U3_GVXX_DUMP_VARS_STATUS_INFO}")
  if(U3_GVXX_DUMP_VARS_DEBUG_STOP)
    message(FATAL_ERROR "${U3_MARK_DEBUG}stop")
  endif()
endfunction(u3_dump_vars)
